// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../app/generated/prisma"
}

generator json {
  provider  = "prisma-json-types-generator"
  namespace = "PrismaJson"
  allowAny  = false
  output   = "../app/generated/prisma-json"
}

generator zod {
  provider = "prisma-zod-generator"
  output = "../app/generated/zod"
  isGenerateInclude = true
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          Int        @id @default(autoincrement())
  cookTime    Int?
  description String
  directions  String[]

  /// [ImageResponse]
  images      Json[]
  name        String
  notes       String?
  prepTime    Int
  servings    String
  slug        String              @unique

  /// [Source]
  source      Json
  categories  Category[]

  /// [IngredientSection]
  sections    Json[]
  user        User?               @relation(fields: [authorId], references: [id])
  authorId    Int?
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  recipes   Recipe[]

  /// [ImageResponse]
  image     Json?
}

model User {
  id          Int        @id @default(autoincrement())
  authId      String   @unique
  name        String
  firstName   String?
  lastName    String?
  email       String   @unique
  image       String?
  recipes     Recipe[]
}

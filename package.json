{
  "name": "food-i-make",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm i && concurrently -n rcp,sto -c blue,magenta 'next dev --webpack' 'pnpm run storybook'",
    "dev:turbopack": "pnpm i && concurrently -n rcp,sto -c blue,magenta 'next dev --turbopack' 'pnpm run storybook'",
    "build": "next build",
    "start": "next start",
    "algolia:reindex": "pnpm exec tsx src/server/search/reindex.ts",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "migrate:run": "tsx ./prisma/scripts/migrateIngredients.ts",
    "migrate:safe": "tsx ./prisma/scripts/safe-migrate.ts",
    "migrate:safe:seed": "RUN_SAFE_SEED=1 tsx ./prisma/scripts/safe-migrate.ts",
    "dev:safe": "tsx ./prisma/scripts/safe-dev.ts",
    "dev:safe:port": "tsx ./prisma/scripts/safe-dev.ts -p",
    "storybook:clean": "rm -rf node_modules/.cache/storybook node_modules/.vite"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/loved-by-the-king": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@imagekit/javascript": "^5.4.1",
    "@imagekit/next": "^2.1.5",
    "@imagekit/nodejs": "^7.9.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@storybook/nextjs": "^10.5.0",
    "algoliasearch": "^5.55.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convert-units": "3.0.0-beta.8",
    "dotenv": "^17.4.2",
    "fraction.js": "^5.3.4",
    "instantsearch.js": "^4.105.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "parse-ingredient": "^2.2.0",
    "pg": "^8.22.0",
    "prisma-zod-generator": "^2.1.4",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-instantsearch": "^7.39.0",
    "react-instantsearch-nextjs": "^1.2.12",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-storybook": "^10.5.0",
    "playwright": "^1.61.1",
    "prisma": "^7.8.0",
    "prisma-json-types-generator": "^5.1.1",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
